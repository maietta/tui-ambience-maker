{
  "name": "omarchy-theme-tui",
  "version": "1.0.0",
  "description": "TUI application for generating Omarchy themes from images",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "omarchy-theme-tui": "./dist/index.js",
    "omarchy-theme": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js",
      "types": "./dist/cli.d.ts"
    },
    "./color": {
      "import": "./dist/color/index.js",
      "types": "./dist/color/index.d.ts"
    },
    "./theme": {
      "import": "./dist/theme/index.js",
      "types": "./dist/theme/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "omarchy",
    "theme",
    "tui",
    "hyprland",
    "colors"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "asciify-image": "^0.1.10",
    "commander": "^11.1.0",
    "ink": "^4.4.1",
    "jimp": "^1.6.1",
    "jszip": "^3.10.1",
    "react": "^18.2.0",
    "react-devtools-core": "^7.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "bun-types": "^1.3.12",
    "eslint": "^8.55.0",
    "typescript": "^5.3.0"
  }
}
