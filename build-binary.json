{
  "name": "build-binary",
  "version": "1.0.0",
  "scripts": {
    "build": "bun build src/index.ts --compile --outfile omarchy-theme-tui",
    "build:linux": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile omarchy-theme-tui-linux",
    "build:windows": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile omarchy-theme-tui.exe",
    "build:macos": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile omarchy-theme-tui-macos",
    "package": "npm run build && cp node_modules/yoga-wasm-web/dist/yoga.wasm . && tar czf omarchy-theme-tui-linux.tar.gz omarchy-theme-tui yoga.wasm"
  }
}
